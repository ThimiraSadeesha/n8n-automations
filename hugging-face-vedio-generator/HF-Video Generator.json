      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Get Video Result",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-128, 112]
    },
    {
      "parameters": {
        "jsCode": "// Gradio's queue API streams Server-Sent Events like:\n// event: complete\n// data: [{\"video\": {\"path\": \"...\", \"url\": \"https://.../file=...\"}}]\n\nconst raw = $input.first().json.data;\nconst text = typeof raw === 'string' ? raw : JSON.stringify(raw);\n\nconst dataLines = text.split('\\n').filter(l => l.trim().startsWith('data:'));\nif (!dataLines.length) {\n  throw new Error('No data lines found in Gradio SSE response: ' + text);\n}\n\nconst lastLine = dataLines[dataLines.length - 1].replace('data:', '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(lastLine);\n} catch (e) {\n  throw new Error('Could not parse Gradio result JSON: ' + lastLine);\n}\n\nconst videoOutput = Array.isArray(parsed)\n  ? parsed.find(item => item && (item.video || item.url || item.path))\n  : parsed;\n\nif (!videoOutput) {\n  throw new Error('No video object found in Gradio output: ' + JSON.stringify(parsed));\n}\n\nconst videoInfo = videoOutput.video || videoOutput;\nconst SPACE_BASE_URL = 'https://YOUR-USERNAME-YOUR-SPACE.hf.space';\nconst videoUrl = videoInfo.url\n  ? videoInfo.url\n  : (videoInfo.path ? `${SPACE_BASE_URL}/file=${videoInfo.path}` : null);\n\nif (!videoUrl) {\n  throw new Error('Could not resolve a public video URL from the Space response.');\n}\n\nconst webhookData = $('Video Request Webhook').first().json.body;\n\nreturn [{\n  json: {\n    videoUrl,\n    phone: webhookData.phone,\n    prompt: webhookData.prompt\n  }\n}];"
      },
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Extract Video URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [96, 112]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.twilio.com/2010-04-01/Accounts/YOUR_TWILIO_ACCOUNT_SID/Messages.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {

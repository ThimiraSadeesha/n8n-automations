      "webhookId": "a1b2c3d4-wait-0005"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://YOUR-USERNAME-YOUR-SPACE.hf.space/gradio_api/call/predict/{{ $json.event_id }}",
        "options": {
